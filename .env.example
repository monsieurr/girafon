# ── Copy this to .env — never commit .env to git ──────────────────────────────

# LLM Provider: anthropic | openai | ollama | groq | mistral
# Default: anthropic
LLM_PROVIDER=anthropic

# Model name — leave blank to use the default for your provider
# anthropic default : claude-sonnet-4-20250514
# openai default    : gpt-4o-mini
# ollama default    : llama3.2   (must be pulled first: ollama pull llama3.2)
# groq default      : llama-3.3-70b-versatile
# mistral default   : mistral-small-latest
LLM_MODEL=

# API keys — only set the key for your chosen provider
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...

# Ollama needs no API key — just run: ollama serve
