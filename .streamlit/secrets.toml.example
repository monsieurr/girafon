# Copy to .streamlit/secrets.toml and set your values.
# Streamlit Cloud reads these secrets; the app maps them to env vars on startup.

LLM_PROVIDER = "ollama"
LLM_MODEL = "llama3.2"

# Cloud API keys (optional)
